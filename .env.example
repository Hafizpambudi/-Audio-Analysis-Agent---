# OpenRouter API key for LLM synthesis
OPENROUTER_API_KEY=your-api-key-here

# Optional: Override default LLM model
# OPENROUTER_MODEL=anthropic/claude-3-opus

# Optional: Set analysis defaults
# SILENCE_THRESHOLD_DB=-50.0
# MIN_SILENCE_DURATION=0.5
# CLIPPING_THRESHOLD_DB=-0.5

# FFmpeg path (repo includes pre-built binaries for Windows)
# Project structure: ffmpegBase/bin/ffmpeg.exe and ffprobe.exe are included
# Uncomment if ffmpeg is not in system PATH:
# FFMPEG_PATH=./ffmpegBase/bin